-- Migration 006: Analytics events table for {{ PROJECT_NAME }}
-- Analytics module — stores user-generated events for tracking and reporting

CREATE TABLE IF NOT EXISTS analytics_events (
    id          UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    user_id     UUID NOT NULL,
    event_name  VARCHAR(100) NOT NULL,
    properties  JSONB DEFAULT '{}',
    timestamp   TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE INDEX idx_analytics_events_user ON analytics_events (user_id);
CREATE INDEX idx_analytics_events_name ON analytics_events (event_name);
CREATE INDEX idx_analytics_events_ts ON analytics_events (timestamp DESC);

-- Composite index for common query pattern: events by type in time range
CREATE INDEX idx_analytics_events_name_ts
    ON analytics_events (event_name, timestamp DESC);

-- Partial index for recent events (last 90 days by default)
-- Adjust the interval based on ANALYTICS_RETENTION_DAYS
CREATE INDEX idx_analytics_events_recent
    ON analytics_events (timestamp DESC)
    WHERE timestamp > NOW() - INTERVAL '90 days';
