"""Analytics routes for {{ PROJECT_NAME }}.

Event tracking, summaries, and event listing with filtering.
"""

from typing import Any, Optional

from fastapi import APIRouter, Depends, Query

from .schemas import TrackEventRequest, TrackEventResponse, AnalyticsSummary, EventList
from .service import track_event, get_summary, get_events_by_type
{% if HAS_AUTH %}
from src.auth.dependencies import get_current_user
{% endif %}

router = APIRouter()


@router.post("/track", response_model=TrackEventResponse, status_code=201)
async def track(
    payload: TrackEventRequest,
{% if HAS_AUTH %}
    current_user: dict[str, Any] = Depends(get_current_user),
{% endif %}
) -> TrackEventResponse:
    """Track an analytics event.

    Args:
        payload: Event data including name, properties, and optional metadata.
        current_user: Authenticated user (injected if auth module is present).

    Returns:
        Confirmation with the event ID.
    """
{% if HAS_AUTH %}
    user_id = current_user["id"]
{% else %}
    user_id = payload.user_id or "anonymous"
{% endif %}
    event_id = await track_event(
        user_id=user_id,
        event_name=payload.event_name,
        properties=payload.properties,
    )
    return TrackEventResponse(event_id=event_id, status="recorded")


@router.get("/summary", response_model=AnalyticsSummary)
async def summary(
    days: int = Query(30, ge=1, le=365, description="Number of days to summarize"),
{% if HAS_AUTH %}
    current_user: dict[str, Any] = Depends(get_current_user),
{% endif %}
) -> AnalyticsSummary:
    """Return aggregated analytics summary for the last N days.

    Args:
        days: Number of days to include in the summary.
        current_user: Authenticated user (injected).

    Returns:
        AnalyticsSummary with totals and breakdowns.
    """
    return await get_summary(days=days)


@router.get("/events", response_model=EventList)
async def list_events(
    event_type: Optional[str] = Query(None, description="Filter by event name"),
    limit: int = Query(100, ge=1, le=1000, description="Max events to return"),
    offset: int = Query(0, ge=0, description="Pagination offset"),
{% if HAS_AUTH %}
    current_user: dict[str, Any] = Depends(get_current_user),
{% endif %}
) -> EventList:
    """List analytics events with optional filtering.

    Args:
        event_type: Filter by event name (optional).
        limit: Maximum number of events to return.
        offset: Pagination offset.
        current_user: Authenticated user (injected).

    Returns:
        Paginated list of events.
    """
    events, total = await get_events_by_type(
        event_type=event_type,
        limit=limit,
        offset=offset,
    )
    return EventList(events=events, total=total, limit=limit, offset=offset)
