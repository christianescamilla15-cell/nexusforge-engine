"""Ticket CRUD routes."""
from fastapi import APIRouter, HTTPException, Query
from src.tickets.models import (
    TicketCreate,
    TicketAssign,
    TicketResponse,
    TicketListResponse,
    TicketStatus,
)
from src.tickets.classifier import classify_ticket
from src.tickets.responder import generate_response
from src.db.client import get_pool

router = APIRouter()


@router.post("/create", response_model=TicketResponse, status_code=201)
async def create_ticket(payload: TicketCreate) -> TicketResponse:
    """Intake a new ticket, classify it with AI, and store it."""
    classification = await classify_ticket(payload.title, payload.description)
    ai_response = await generate_response(
        payload.title, payload.description, classification.category
    )

    pool = await get_pool()
    async with pool.acquire() as conn:
        row = await conn.fetchrow(
            """
            INSERT INTO tickets (title, description, urgency, category, status,
                                 assigned_team, ai_response)
            VALUES ($1, $2, $3, $4, $5, $6, $7)
            RETURNING *
            """,
            payload.title,
            payload.description,
            classification.urgency.value,
            classification.category.value,
            TicketStatus.open.value,
            classification.suggested_team,
            ai_response,
        )
    return TicketResponse(**dict(row))


@router.get("/", response_model=TicketListResponse)
async def list_tickets(
    status: TicketStatus | None = None,
    limit: int = Query(default=50, le=200),
    offset: int = Query(default=0, ge=0),
) -> TicketListResponse:
    """List tickets with optional status filter and pagination."""
    pool = await get_pool()
    async with pool.acquire() as conn:
        where = "WHERE status = $1" if status else ""
        params: list = [status.value] if status else []

        count_sql = f"SELECT count(*) FROM tickets {where}"
        total = await conn.fetchval(count_sql, *params)

        idx = len(params) + 1
        data_sql = (
            f"SELECT * FROM tickets {where} "
            f"ORDER BY created_at DESC LIMIT ${idx} OFFSET ${idx + 1}"
        )
        rows = await conn.fetch(data_sql, *params, limit, offset)

    return TicketListResponse(
        tickets=[TicketResponse(**dict(r)) for r in rows],
        total=total,
    )


@router.get("/{ticket_id}", response_model=TicketResponse)
async def get_ticket(ticket_id: int) -> TicketResponse:
    """Retrieve a single ticket by ID."""
    pool = await get_pool()
    async with pool.acquire() as conn:
        row = await conn.fetchrow("SELECT * FROM tickets WHERE id = $1", ticket_id)
    if not row:
        raise HTTPException(status_code=404, detail="Ticket not found")
    return TicketResponse(**dict(row))


@router.put("/{ticket_id}/assign", response_model=TicketResponse)
async def assign_ticket(ticket_id: int, payload: TicketAssign) -> TicketResponse:
    """Assign a ticket to a team."""
    pool = await get_pool()
    async with pool.acquire() as conn:
        row = await conn.fetchrow(
            """
            UPDATE tickets
            SET assigned_team = $2, status = $3, updated_at = now()
            WHERE id = $1
            RETURNING *
            """,
            ticket_id,
            payload.assigned_team,
            TicketStatus.in_progress.value,
        )
    if not row:
        raise HTTPException(status_code=404, detail="Ticket not found")
    return TicketResponse(**dict(row))


@router.put("/{ticket_id}/resolve", response_model=TicketResponse)
async def resolve_ticket(ticket_id: int) -> TicketResponse:
    """Mark a ticket as resolved."""
    pool = await get_pool()
    async with pool.acquire() as conn:
        row = await conn.fetchrow(
            """
            UPDATE tickets
            SET status = $2, updated_at = now()
            WHERE id = $1
            RETURNING *
            """,
            ticket_id,
            TicketStatus.resolved.value,
        )
    if not row:
        raise HTTPException(status_code=404, detail="Ticket not found")
    return TicketResponse(**dict(row))
