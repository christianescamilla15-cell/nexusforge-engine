"""Pydantic models for the ticket system."""
from datetime import datetime
from enum import Enum
from typing import Optional
from pydantic import BaseModel, Field


class Urgency(str, Enum):
    """Ticket urgency levels."""
    critical = "critical"
    high = "high"
    medium = "medium"
    low = "low"


class Category(str, Enum):
    """Ticket category types."""
    billing = "billing"
    technical = "technical"
    general = "general"
    account = "account"


class TicketStatus(str, Enum):
    """Ticket lifecycle states."""
    open = "open"
    in_progress = "in_progress"
    resolved = "resolved"
    closed = "closed"


class TicketCreate(BaseModel):
    """Schema for creating a new ticket."""
    title: str = Field(..., min_length=3, max_length=200)
    description: str = Field(..., min_length=10, max_length=5000)


class TicketClassification(BaseModel):
    """AI-generated classification result."""
    urgency: Urgency
    category: Category
    confidence: float = Field(ge=0.0, le=1.0)
    suggested_team: str


class TicketAssign(BaseModel):
    """Schema for assigning a ticket."""
    assigned_team: str = Field(..., min_length=1, max_length=100)


class TicketResponse(BaseModel):
    """Full ticket representation returned by the API."""
    id: int
    title: str
    description: str
    urgency: Urgency
    category: Category
    status: TicketStatus
    assigned_team: Optional[str] = None
    ai_response: Optional[str] = None
    created_at: datetime
    updated_at: Optional[datetime] = None

    class Config:
        from_attributes = True


class TicketListResponse(BaseModel):
    """Paginated ticket list."""
    tickets: list[TicketResponse]
    total: int
