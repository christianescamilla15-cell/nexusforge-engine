"""{{ PROJECT_NAME }} -- Agentic SaaS platform with multi-agent orchestration."""
from contextlib import asynccontextmanager
from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
{% if HAS_AUTH %}
from src.auth.router import router as auth_router
{% endif %}
from src.agents.registry import router as agents_router
from src.engine.executor import router as workflows_router
{% if HAS_BILLING %}
from src.billing.router import router as billing_router
{% endif %}
{% if HAS_NOTIFICATIONS %}
from src.notifications.router import router as notifications_router
{% endif %}
{% if HAS_ANALYTICS %}
from src.analytics.router import router as analytics_router
{% endif %}
from src.db.client import get_pool, close_pool


@asynccontextmanager
async def lifespan(application: FastAPI):
    """Manage startup/shutdown lifecycle."""
    await get_pool()
    yield
    await close_pool()


app = FastAPI(title="{{ PROJECT_NAME }}", version="0.1.0", lifespan=lifespan)
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_methods=["*"],
    allow_headers=["*"],
)

{% if HAS_AUTH %}
app.include_router(auth_router, prefix="/api/auth", tags=["auth"])
{% endif %}
app.include_router(agents_router, prefix="/api/agents", tags=["agents"])
app.include_router(workflows_router, prefix="/api/workflows", tags=["workflows"])
{% if HAS_BILLING %}
app.include_router(billing_router, prefix="/api/billing", tags=["billing"])
{% endif %}
{% if HAS_NOTIFICATIONS %}
app.include_router(notifications_router, prefix="/api/notifications", tags=["notifications"])
{% endif %}
{% if HAS_ANALYTICS %}
app.include_router(analytics_router, prefix="/api/analytics", tags=["analytics"])
{% endif %}


@app.get("/api/health")
async def health():
    """Health check endpoint."""
    return {"status": "ok", "service": "{{ PROJECT_NAME }}"}
