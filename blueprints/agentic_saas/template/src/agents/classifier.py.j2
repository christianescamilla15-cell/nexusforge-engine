"""Classifier agent -- categorizes input text using LLM."""
import json
import os
from typing import Any

{% if LLM_PROVIDER == "anthropic" or not LLM_PROVIDER %}
import anthropic
{% else %}
import openai
{% endif %}

from src.agents.base import BaseAgent
from src.agents.registry import register_agent

_SYSTEM_PROMPT = """\
You are a text classifier. Given input text and a list of categories,
return a JSON object with:
- category: the best matching category
- confidence: float 0.0-1.0
- reasoning: one sentence explaining the choice

Return ONLY valid JSON.
"""


class ClassifierAgent(BaseAgent):
    """Classifies input text into one of the configured categories."""

    async def run(self, input_data: dict[str, Any]) -> dict[str, Any]:
        """Classify the input text.

        Args:
            input_data: Must contain 'text' and 'categories' (list of strings).

        Returns:
            Dict with category, confidence, and reasoning.
        """
        text = input_data.get("text", "")
        categories = input_data.get("categories", ["general"])

        user_message = (
            f"Categories: {', '.join(categories)}\n\n"
            f"Text to classify:\n{text[:2000]}"
        )

{% if LLM_PROVIDER == "anthropic" or not LLM_PROVIDER %}
        client = anthropic.AsyncAnthropic(api_key=os.environ["ANTHROPIC_API_KEY"])
        response = await client.messages.create(
            model="claude-sonnet-4-20250514",
            max_tokens=256,
            system=_SYSTEM_PROMPT,
            messages=[{"role": "user", "content": user_message}],
        )
        raw = response.content[0].text
{% else %}
        client = openai.AsyncOpenAI(api_key=os.environ["OPENAI_API_KEY"])
        response = await client.chat.completions.create(
            model="gpt-4o-mini",
            max_tokens=256,
            messages=[
                {"role": "system", "content": _SYSTEM_PROMPT},
                {"role": "user", "content": user_message},
            ],
        )
        raw = response.choices[0].message.content or "{}"
{% endif %}

        try:
            return json.loads(raw.strip())
        except json.JSONDecodeError:
            return {"category": categories[0], "confidence": 0.0, "reasoning": "Failed to parse LLM response"}


# Auto-register on import
register_agent("classifier", ClassifierAgent)
