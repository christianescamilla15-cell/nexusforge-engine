-- Migration 001: Core tables for {{ PROJECT_NAME }} agentic workflow platform

CREATE TYPE workflow_status AS ENUM ('pending', 'running', 'completed', 'failed', 'cancelled');
CREATE TYPE step_status AS ENUM ('pending', 'running', 'completed', 'failed', 'skipped');

-- Workflow definitions (reusable templates)
CREATE TABLE IF NOT EXISTS workflows (
    id          SERIAL PRIMARY KEY,
    name        VARCHAR(200)     NOT NULL,
    description TEXT,
    steps_json  JSONB            NOT NULL,
    created_by  VARCHAR(100),
    created_at  TIMESTAMPTZ      NOT NULL DEFAULT now(),
    updated_at  TIMESTAMPTZ
);

-- Individual workflow runs
CREATE TABLE IF NOT EXISTS workflow_runs (
    id            UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    workflow_id   INTEGER          NOT NULL REFERENCES workflows(id) ON DELETE CASCADE,
    status        workflow_status  NOT NULL DEFAULT 'pending',
    initial_input JSONB            NOT NULL DEFAULT '{}'::jsonb,
    final_output  JSONB,
    started_at    TIMESTAMPTZ,
    completed_at  TIMESTAMPTZ,
    created_at    TIMESTAMPTZ      NOT NULL DEFAULT now()
);

-- Per-step execution records
CREATE TABLE IF NOT EXISTS step_executions (
    id           SERIAL PRIMARY KEY,
    run_id       UUID            NOT NULL REFERENCES workflow_runs(id) ON DELETE CASCADE,
    step_id      VARCHAR(100)    NOT NULL,
    agent_id     VARCHAR(100)    NOT NULL,
    status       step_status     NOT NULL DEFAULT 'pending',
    input_data   JSONB,
    output_data  JSONB,
    error        TEXT,
    duration_ms  NUMERIC(10, 2)  DEFAULT 0,
    started_at   TIMESTAMPTZ,
    completed_at TIMESTAMPTZ
);

CREATE INDEX idx_workflow_runs_workflow ON workflow_runs (workflow_id);
CREATE INDEX idx_workflow_runs_status ON workflow_runs (status);
CREATE INDEX idx_workflow_runs_created ON workflow_runs (created_at DESC);
CREATE INDEX idx_step_executions_run ON step_executions (run_id);
CREATE INDEX idx_step_executions_status ON step_executions (status);
