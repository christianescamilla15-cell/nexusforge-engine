"""AI field extraction from invoice documents."""
import json
import os
from datetime import date
from decimal import Decimal
from typing import Any

{% if LLM_PROVIDER == "anthropic" or not LLM_PROVIDER %}
import anthropic
{% else %}
import openai
{% endif %}

from src.invoices.models import InvoiceExtraction, LineItem

_SYSTEM_PROMPT = """\
You are an invoice data extraction specialist. Given the raw text of an invoice
document, extract structured data and return it as a JSON object with these fields:

- vendor_name: string (the company that issued the invoice)
- invoice_number: string or null
- invoice_date: string in YYYY-MM-DD format
- due_date: string in YYYY-MM-DD or null
- subtotal: number
- tax: number or null
- total_amount: number
- currency: string (ISO 4217 code, default "USD")
- line_items: array of objects with {description, quantity, unit_price, total}
- confidence: float 0.0-1.0 representing extraction quality

Return ONLY valid JSON, no markdown fences.
"""


async def extract_invoice_fields(text: str, filename: str) -> InvoiceExtraction:
    """Extract structured invoice data from raw document text.

    Args:
        text: The raw text content of the invoice document.
        filename: Original filename for context.

    Returns:
        InvoiceExtraction with all parsed fields.
    """
    user_message = f"Filename: {filename}\n\nDocument text:\n{text[:4000]}"

{% if LLM_PROVIDER == "anthropic" or not LLM_PROVIDER %}
    client = anthropic.AsyncAnthropic(api_key=os.environ["ANTHROPIC_API_KEY"])
    response = await client.messages.create(
        model="claude-sonnet-4-20250514",
        max_tokens=1024,
        system=_SYSTEM_PROMPT,
        messages=[{"role": "user", "content": user_message}],
    )
    raw: str = response.content[0].text
{% else %}
    client = openai.AsyncOpenAI(api_key=os.environ["OPENAI_API_KEY"])
    response = await client.chat.completions.create(
        model="gpt-4o-mini",
        max_tokens=1024,
        messages=[
            {"role": "system", "content": _SYSTEM_PROMPT},
            {"role": "user", "content": user_message},
        ],
    )
    raw = response.choices[0].message.content or "{}"
{% endif %}

    data = _parse_extraction(raw)
    return _to_model(data)


def _parse_extraction(raw: str) -> dict[str, Any]:
    """Parse LLM JSON response, handling markdown fences."""
    text = raw.strip()
    if text.startswith("```"):
        lines = text.split("\n")
        text = "\n".join(lines[1:-1])
    try:
        return json.loads(text)
    except json.JSONDecodeError:
        return {}


def _to_model(data: dict[str, Any]) -> InvoiceExtraction:
    """Convert raw dict to InvoiceExtraction, with safe defaults."""
    line_items = [
        LineItem(
            description=li.get("description", "Unknown"),
            quantity=Decimal(str(li.get("quantity", 1))),
            unit_price=Decimal(str(li.get("unit_price", 0))),
            total=Decimal(str(li.get("total", 0))),
        )
        for li in data.get("line_items", [])
    ]

    return InvoiceExtraction(
        vendor_name=data.get("vendor_name", "Unknown Vendor"),
        invoice_number=data.get("invoice_number"),
        invoice_date=date.fromisoformat(data["invoice_date"]) if data.get("invoice_date") else date.today(),
        due_date=date.fromisoformat(data["due_date"]) if data.get("due_date") else None,
        subtotal=Decimal(str(data.get("subtotal", 0))),
        tax=Decimal(str(data["tax"])) if data.get("tax") is not None else None,
        total_amount=Decimal(str(data.get("total_amount", 0))),
        currency=data.get("currency", "USD"),
        line_items=line_items,
        confidence=float(data.get("confidence", 0.5)),
    )
