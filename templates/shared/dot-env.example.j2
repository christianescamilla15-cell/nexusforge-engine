{% for var in ENV_VARS %}
# {{ var.description }}
{% if var.required %}
{{ var.name }}={{ var.get('example', '') }}
{% else %}
# {{ var.name }}={{ var.get('example', var.get('default', '')) }}
{% endif %}
{% endfor %}
