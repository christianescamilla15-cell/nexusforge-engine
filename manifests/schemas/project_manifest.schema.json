{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexusforge.dev/schemas/project_manifest.schema.json",
  "title": "NexusForge Project Manifest",
  "description": "Schema for validating NexusForge Engine project manifests. The manifest is the single source of truth for project configuration.",
  "type": "object",
  "required": ["version", "project", "blueprint", "stack"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Manifest schema version",
      "pattern": "^\\d+\\.\\d+$",
      "examples": ["1.0"]
    },
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of when the manifest was generated",
      "format": "date-time"
    },
    "project": {
      "type": "object",
      "description": "Core project metadata",
      "required": ["name", "type"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable project name",
          "minLength": 1,
          "maxLength": 100
        },
        "description": {
          "type": "string",
          "description": "Project description"
        },
        "type": {
          "type": "string",
          "description": "Project type matching a blueprint ID",
          "enum": ["agentic_saas", "ticket_system", "invoice_processor"]
        }
      },
      "additionalProperties": false
    },
    "blueprint": {
      "type": "object",
      "description": "Blueprint used to generate the project",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Blueprint identifier"
        },
        "name": {
          "type": "string",
          "description": "Blueprint display name"
        }
      },
      "additionalProperties": false
    },
    "stack": {
      "type": "object",
      "description": "Technology stack configuration",
      "properties": {
        "framework": {
          "type": "string",
          "description": "Backend framework",
          "enum": ["fastapi", "flask", "django"]
        },
        "language": {
          "type": "string",
          "description": "Primary programming language",
          "enum": ["python", "typescript", "go"]
        },
        "state_management": {
          "type": "string",
          "description": "State/cache technology"
        },
        "database": {
          "type": "string",
          "description": "Primary database"
        },
        "queue": {
          "type": "string",
          "description": "Task queue technology"
        },
        "frontend": {
          "type": "string",
          "description": "Frontend framework"
        }
      },
      "additionalProperties": false
    },
    "modules": {
      "type": "array",
      "description": "List of installed modules",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Module identifier"
          },
          "name": {
            "type": "string",
            "description": "Module display name"
          },
          "requires": {
            "type": "array",
            "description": "Module dependencies",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "env_contract": {
      "type": "array",
      "description": "Environment variables required by the project",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Environment variable name",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          },
          "description": {
            "type": "string",
            "description": "What this variable is for"
          },
          "required": {
            "type": "boolean",
            "description": "Whether this variable is required"
          },
          "example": {
            "type": "string",
            "description": "Example value"
          },
          "default": {
            "type": "string",
            "description": "Default value if not set"
          }
        },
        "additionalProperties": false
      }
    },
    "base_structure": {
      "type": "array",
      "description": "List of directories in the project structure",
      "items": {
        "type": "string"
      }
    },
    "post_generation_hooks": {
      "type": "array",
      "description": "Commands to run after project generation",
      "items": {
        "type": "object",
        "required": ["command"],
        "properties": {
          "command": {
            "type": "string",
            "description": "Shell command to execute"
          },
          "description": {
            "type": "string",
            "description": "What this hook does"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
